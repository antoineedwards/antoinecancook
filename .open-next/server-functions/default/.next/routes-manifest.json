      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/recipes/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/category/[slug]",
      "regex": "^/category/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/category/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/cuisine/[slug]",
      "regex": "^/cuisine/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/cuisine/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/ingredient/[slug]",
      "regex": "^/ingredient/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/ingredient/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/recipes/[slug]",
      "regex": "^/recipes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/recipes/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
