{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/recipes/[slug]/edit",
      "regex": "^/admin/recipes/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/admin/recipes/(?<nxtPslug>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/api/admin/recipes/[slug]",
      "regex": "^/api/admin/recipes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/admin/recipes/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/recipes/[slug]",
