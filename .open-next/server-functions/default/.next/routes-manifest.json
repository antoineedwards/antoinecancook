      "namedRegex": "^/api/admin/upload\\-url(?:/)?$"
    },
    {
      "page": "/api/recipes",
      "regex": "^/api/recipes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/recipes(?:/)?$"
